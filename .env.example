# ── Uni-OS Environment Variables ─────────────────────────────────────────────
# Copy this file to .env and fill in your own values.
#   cp .env.example .env
#
# NEVER commit your real .env file — it's already in .gitignore.

# ── Google Vertex AI / Gemini ─────────────────────────────────────────────────
# Your Google Cloud API key (enables Gemini LLM calls via Vertex AI)
# Get one at: https://console.cloud.google.com/apis/credentials
GOOGLE_API_KEY="your-google-api-key-here"

# Your Google Cloud project ID (the project with Vertex AI enabled)
# Find it at: https://console.cloud.google.com/home/dashboard
GOOGLE_CLOUD_QUOTA_PROJECT=your-gcp-project-id

# ── University of Waterloo OpenData API ───────────────────────────────────────
# Free API key for the UW OpenData API (courses, exams, food, events, etc.)
# Register at: https://openapi.data.uwaterloo.ca
WATERLOO_API_KEY=your-waterloo-api-key-here

# ── Canvas LMS (Optional) ─────────────────────────────────────────────────────
# Your Canvas API token for pulling assignment deadlines
# Generate at: Canvas → Account → Settings → New Access Token
# CANVAS_API_KEY=your-canvas-api-token-here
# CANVAS_BASE_URL=https://canvas.uwaterloo.ca
